#!/usr/bin/env bash
# cca — Claude Code Accounts: manage multiple Claude Code (CLI) subscriptions
# side by side. Auth isolation uses CLAUDE_CODE_OAUTH_TOKEN (per Anthropic's
# documented auth precedence), which works on macOS, Linux, and Windows
# regardless of where the Keychain entry lives.
#
# Scope: Claude Code CLI only. Claude Desktop / Cowork is a separate problem.
# https://github.com/<owner>/cca
set -euo pipefail

VERSION="0.1.0"

CLAUDE_HOME="${HOME}/.claude"
PROFILE_PREFIX="${HOME}/.claude-"

# Items in ~/.claude/ that can be copied into new profiles.
# Auth and per-session state are intentionally excluded.
COPYABLE_ITEMS=(
  CLAUDE.md
  agents
  commands
  hooks
  keybindings.json
  mcp.json
  plugins
  rules
  settings.json
  skills
  statusline.sh
)

# Per-profile state lives in ~/.claude-<name>/ and is never touched by cca
# after `add`/`refresh`. The token file is the one cca writes:
TOKEN_FILE_NAME=".cca-token"
PROFILE_MARKER_NAME=".cca-profile"
LABEL_FILE_NAME=".cca-label"

# ─────────────────────────────────────────────────────────────────────────────
# helpers
# ─────────────────────────────────────────────────────────────────────────────

_die()  { printf 'cca: %s\n' "$*" >&2; exit 1; }
_warn() { printf 'cca: %s\n' "$*" >&2; }
_info() { printf '%s\n' "$*" >&2; }

# Terminal styling. Empty strings when stderr isn't a TTY, NO_COLOR is set,
# or tput is unavailable — so output stays clean in pipelines.
if [ -t 2 ] && [ -z "${NO_COLOR:-}" ] && command -v tput >/dev/null 2>&1; then
  BOLD="$(tput bold 2>/dev/null || true)"
  DIM="$(tput dim 2>/dev/null || true)"
  CYAN="$(tput setaf 6 2>/dev/null || true)"
  YELLOW="$(tput setaf 3 2>/dev/null || true)"
  GREEN="$(tput setaf 2 2>/dev/null || true)"
  RESET="$(tput sgr0 2>/dev/null || true)"
  # Orange — xterm-256 color 208. Fall back to yellow if the terminal
  # only supports 8/16 colors.
  if [ "$(tput colors 2>/dev/null || echo 0)" -ge 256 ]; then
    ORANGE="$(tput setaf 208 2>/dev/null || true)"
  else
    ORANGE="$YELLOW"
  fi
else
  BOLD=''; DIM=''; CYAN=''; YELLOW=''; GREEN=''; ORANGE=''; RESET=''
fi

# Read a profile dir's label, if any. Empty string if no label is set.
_read_label() {
  local d="${1%/}"
  local f="$d/$LABEL_FILE_NAME"
  [ -f "$f" ] || return 0
  head -n1 "$f" 2>/dev/null | tr -d '[:space:]'
}

# Resolve <name> → absolute profile dir.
#   "main" / "default" always → ~/.claude (regardless of label)
#   <name> matching a label → that profile's dir
#   <name> otherwise → ~/.claude-<name>
_profile_dir() {
  local name="$1"
  if [ "$name" = "main" ] || [ "$name" = "default" ]; then
    printf '%s' "$CLAUDE_HOME"
    return
  fi
  # Scan for label match across main + all ~/.claude-* profiles.
  local d label
  for d in "$CLAUDE_HOME" "${PROFILE_PREFIX}"*; do
    [ -d "$d" ] || continue
    label="$(_read_label "$d")"
    if [ -n "$label" ] && [ "$label" = "$name" ]; then
      printf '%s' "$d"
      return
    fi
  done
  printf '%s%s' "$PROFILE_PREFIX" "$name"
}

# Inverse: absolute dir → display name. Prefers a label if present, otherwise
# derives from the dir name. ~/.claude with no label → "main".
_profile_name_of_dir() {
  local d="${1%/}"
  local label
  label="$(_read_label "$d")"
  if [ -n "$label" ]; then
    printf '%s' "$label"
    return
  fi
  if [ "$d" = "$CLAUDE_HOME" ]; then
    printf 'main'
  else
    printf '%s' "${d#$PROFILE_PREFIX}"
  fi
}

# Currently-active profile resolution.
# Priority: CLAUDE_CODE_OAUTH_TOKEN (if matches a known profile's token) →
# CLAUDE_CONFIG_DIR → main.
_active_dir() {
  if [ -n "${CLAUDE_CONFIG_DIR:-}" ] && [ -d "${CLAUDE_CONFIG_DIR}" ]; then
    printf '%s' "$CLAUDE_CONFIG_DIR"
  else
    printf '%s' "$CLAUDE_HOME"
  fi
}

# List cca-managed profile dirs, one per line. Always lists main first.
_list_profile_dirs() {
  printf '%s\n' "$CLAUDE_HOME"
  # shellcheck disable=SC2231
  for d in ${PROFILE_PREFIX}*; do
    [ -d "$d" ] || continue
    [ -f "$d/$PROFILE_MARKER_NAME" ] || continue
    printf '%s\n' "$d"
  done
}

# Returns 0 if profile has a stored token, 1 otherwise.
_has_token() {
  local dir="$1"
  [ -f "$dir/$TOKEN_FILE_NAME" ]
}

# Print stored token (or empty) for a profile dir.
_read_token() {
  local dir="$1"
  [ -f "$dir/$TOKEN_FILE_NAME" ] || return 0
  cat "$dir/$TOKEN_FILE_NAME"
}

# ─────────────────────────────────────────────────────────────────────────────
# commands
# ─────────────────────────────────────────────────────────────────────────────

# Extract a short description (≤60 chars) from a file or directory.
# type: command | agent | skill | rule | hook
_extract_description() {
  local type="$1" path="$2" desc=""

  case "$type" in
    command|agent)
      if [ -f "$path" ]; then
        desc=$(grep -m1 '^description:' "$path" 2>/dev/null \
               | sed 's/^description:[[:space:]]*//' \
               | tr -d '"'"'")
        if [ -z "$desc" ]; then
          desc=$(grep -v '^[[:space:]]*$' "$path" 2>/dev/null \
                 | grep -v '^---' | grep -v '^#' \
                 | head -1 | sed 's/^[[:space:]]*//')
        fi
      fi
      ;;
    skill)
      local sf=""
      [ -f "$path/SKILL.md" ] && sf="$path/SKILL.md"
      if [ -z "$sf" ]; then
        sf=$(find "$path" -maxdepth 1 -name "*.md" 2>/dev/null | sort | head -1)
      fi
      if [ -n "$sf" ]; then
        desc=$(grep -m1 '^description:' "$sf" 2>/dev/null \
               | sed 's/^description:[[:space:]]*//' \
               | tr -d '"'"'")
      fi
      ;;
    rule)
      [ -f "$path" ] && desc=$(grep -vm1 '^[[:space:]]*$' "$path" 2>/dev/null \
                               | head -1 | sed 's/^#[[:space:]]*//')
      ;;
    hook)
      if [ -f "$path" ]; then
        desc=$(grep -m1 '^#[^!]' "$path" 2>/dev/null | sed 's/^#[[:space:]]*//')
      elif [ -d "$path" ]; then
        desc="hook directory"
      fi
      ;;
  esac

  printf '%s' "${desc:0:60}"
}

_picker() {
  # Requires interactive TTY on stdin + stderr (UI goes to stderr so callers
  # can capture the selection via stdout).
  if [ ! -t 0 ] || [ ! -t 2 ]; then
    return 1
  fi

  local profiles=() dir
  while read -r dir; do
    [ -d "$dir" ] || continue
    profiles+=("$(_profile_name_of_dir "$dir")")
  done < <(_list_profile_dirs)

  local n=${#profiles[@]}
  if [ "$n" -le 1 ]; then
    _warn "only the main profile exists. Run 'cca add <name>' to create another."
    return 1
  fi

  local active sel=0 i
  active="$(_profile_name_of_dir "$(_active_dir)")"
  for i in "${!profiles[@]}"; do
    if [ "${profiles[$i]}" = "$active" ]; then sel=$i; break; fi
  done

  # Hide cursor + restore on any exit path.
  tput civis >&2 2>/dev/null || true
  local _restored=0
  _picker_cleanup() {
    [ "$_restored" -eq 1 ] && return
    _restored=1
    tput cnorm >&2 2>/dev/null || true
  }
  trap _picker_cleanup EXIT INT TERM

  # Reserve vertical space: one line per profile + one hint line.
  local total=$((n + 1))
  for ((i=0; i<total; i++)); do printf '\n' >&2; done

  while true; do
    # Move cursor back to the top of our widget.
    tput cuu "$total" >&2

    for i in "${!profiles[@]}"; do
      tput el >&2
      local cur_marker=''
      [ "${profiles[$i]}" = "$active" ] && cur_marker=" ${DIM}(current)${RESET}"
      if [ "$i" -eq "$sel" ]; then
        printf '%s❯%s %s%s%s%s\n' "$ORANGE" "$RESET" "$BOLD" "${profiles[$i]}" "$RESET" "$cur_marker" >&2
      else
        printf '  %s%s\n' "${profiles[$i]}" "$cur_marker" >&2
      fi
    done
    tput el >&2
    printf '%s↑/↓ navigate · enter to select · esc / q to cancel%s\n' "$DIM" "$RESET" >&2

    local k r1='' r2=''
    IFS= read -rsn1 k
    case "$k" in
      $'\033')
        # Escape sequence (arrow key) or plain ESC. macOS ships bash 3.2 which
        # doesn't support fractional -t, so read one byte at a time with a
        # 1-second timeout — long enough for terminals that send the sequence
        # in multiple chunks, short enough to feel responsive when plain ESC
        # is what the user actually pressed.
        IFS= read -rsn1 -t 1 r1 2>/dev/null || r1=''
        if [ "$r1" = "[" ]; then
          IFS= read -rsn1 -t 1 r2 2>/dev/null || r2=''
          case "$r2" in
            A) sel=$(( (sel + n - 1) % n )) ;;  # up
            B) sel=$(( (sel + 1) % n )) ;;       # down
            *) : ;;                              # ignore other arrows/keys
          esac
        else
          # plain ESC — cancel
          _picker_cleanup; trap - EXIT INT TERM; return 1
        fi
        ;;
      '')
        # Enter: clear the hint line, restore cursor, emit selection on stdout.
        tput el >&2
        _picker_cleanup
        trap - EXIT INT TERM
        printf '%s' "${profiles[$sel]}"
        return 0
        ;;
      q|Q)
        _picker_cleanup
        trap - EXIT INT TERM
        return 1
        ;;
    esac
  done
}

cmd_help() {
  # Re-evaluate styling based on stdout (where help is written) being a TTY,
  # so piping to a file or pager doesn't sprinkle ANSI codes.
  local B='' D='' C='' R=''
  if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && command -v tput >/dev/null 2>&1; then
    B="$(tput bold 2>/dev/null || true)"
    D="$(tput dim 2>/dev/null || true)"
    R="$(tput sgr0 2>/dev/null || true)"
    # Use Claude orange (xterm-256 color 208) for command names + paths;
    # fall back to yellow when the terminal only supports 16 colors.
    if [ "$(tput colors 2>/dev/null || echo 0)" -ge 256 ]; then
      C="$(tput setaf 208 2>/dev/null || true)"
    else
      C="$(tput setaf 3 2>/dev/null || true)"
    fi
  fi

  # Helper: format a command row.  $1 = command (cyan), $2 = description (plain).
  local row='printf "  %s%-26s%s%s\n"'

  cat <<EOF
${B}${C}cca${R} ${D}— Claude Code Accounts (${VERSION})${R}

Run multiple Claude Code (CLI) subscriptions side by side. Each profile is
fully independent — copy exactly what you need at creation time, or add
more later with ${C}cca sync${R}.

${D}Scope: Claude Code CLI only — Claude Desktop / Cowork is not managed by cca.${R}

${B}Usage:${R}
  ${C}cca${R}                       interactive picker — choose a profile to switch to
  ${C}cca ls${R}                    list profiles, mark active, show auth state
  ${C}cca active${R}                print active profile name
  ${C}cca add${R} <name>            create profile <name> (interactive item picker)
  ${C}cca login${R} <name>          run \`claude setup-token\` and save token for <name>
  ${C}cca switch${R} <name>         switch the active profile in this shell
  ${C}cca rename${R} <old> <new>    rename profile (also: ${C}cca mv${R})
  ${C}cca rm${R} <name>             delete profile <name>
  ${C}cca sync${R} <name>           copy items from ~/.claude/ into a profile
  ${C}cca usage${R} [name]          heatmap + summary for one profile
                              ${D}(defaults to the active profile)${R}
  ${C}cca usage${R} --all           same, for every profile
  ${C}cca init${R} [shell]          install shell wrapper into your rc file
                              ${D}(short prompt with [?] for details)${R}
  ${C}cca init${R} --verbose        show full details up front (no [?] needed)
  ${C}cca init${R} -y               non-interactive install
  ${C}cca init${R} --print          print the wrapper instead of installing
  ${C}cca version${R}
  ${C}cca help${R}

${B}Switching:${R}
  ${C}cca switch personal${R}       ${D}# use the personal profile in this shell${R}
  ${C}cca switch main${R}           ${D}# back to main (Keychain auth)${R}
  ${C}cca${R}                       ${D}# interactive picker${R}

  ${D}Requires the shell wrapper (one-time setup):${R}  ${C}cca init${R}
  ${D}Without it, wrap manually:${R}  ${C}eval "\$(cca switch <name>)"${R}
EOF
}

cmd_version() { printf 'cca %s\n' "$VERSION"; }

cmd_ls() {
  local active_dir
  active_dir="$(_active_dir)"
  printf '%-12s %-8s %-12s %s\n' 'PROFILE' 'STATUS' 'AUTH' 'PATH'
  while read -r dir; do
    [ -d "$dir" ] || continue
    local name mark auth
    name="$(_profile_name_of_dir "$dir")"
    if [ "$dir" = "$active_dir" ]; then mark='* active'; else mark='-'; fi
    if [ "$dir" = "$CLAUDE_HOME" ]; then
      auth='keychain'
    elif _has_token "$dir"; then
      auth='token'
    else
      auth='(no token)'
    fi
    printf '%-12s %-8s %-12s %s\n' "$name" "$mark" "$auth" "$dir"
  done < <(_list_profile_dirs)
}

cmd_active() {
  _profile_name_of_dir "$(_active_dir)"
  echo
}

cmd_add() {
  local name="${1:-}"
  [ -n "$name" ] || _die "usage: cca add <name>"
  [ "$name" != "main" ] && [ "$name" != "default" ] || _die "reserved name: $name"
  local dir
  dir="$(_profile_dir "$name")"
  # _profile_dir returns the label-matched dir if the name is already a label.
  # If it matches an existing profile (including main with this label), reject.
  if [ -d "$dir" ]; then
    _die "profile already exists with name '$name' at $dir"
  fi
  [ ! -e "$dir" ] || _die "profile already exists: $dir"

  mkdir -p "$dir"
  : > "$dir/$PROFILE_MARKER_NAME"
  # Pre-create projects/ so tools like ccusage don't error before the
  # profile has any sessions yet.
  mkdir -p "$dir/projects"
  local item src
  for item in "${COPYABLE_ITEMS[@]}"; do
    src="$CLAUDE_HOME/$item"
    if [ -e "$src" ]; then
      ln -s "$src" "$dir/$item"
    fi
  done
  printf 'Created profile %s at %s\n' "$name" "$dir"
  printf 'Next: cca login %s\n' "$name"
}

cmd_sync() {
  local name="${1:-}"
  [ -n "$name" ] || _die "usage: cca sync <name>"
  local dir
  dir="$(_profile_dir "$name")"
  [ -d "$dir" ] || _die "no such profile: $name (run: cca add $name)"
  _info "cca sync: not yet implemented — coming in next task"
}

cmd_refresh() {
  local name="${1:-}"
  [ -n "$name" ] || _die "usage: cca sync <name>  (refresh has been renamed to sync)"
  _warn "'refresh' is now 'sync'. Running: cca sync $name"
  cmd_sync "$name"
}

cmd_rename() {
  local old="${1:-}" new="${2:-}"
  [ -n "$old" ] && [ -n "$new" ] || _die "usage: cca rename <old> <new>"
  [ "$old" != "$new" ] || _die "names are the same"

  local old_dir
  old_dir="$(_profile_dir "$old")"
  [ -d "$old_dir" ] || _die "no such profile: $old"

  # Renaming TO 'main'/'default': only allowed when undoing a label on ~/.claude.
  if [ "$new" = "main" ] || [ "$new" = "default" ]; then
    if [ "$old_dir" = "$CLAUDE_HOME" ]; then
      rm -f "$CLAUDE_HOME/$LABEL_FILE_NAME"
      printf 'Removed label; %s%s%s is back to "main".\n' "$ORANGE" "$CLAUDE_HOME" "$RESET"
      return
    fi
    _die "reserved name: $new"
  fi

  # Check the new name doesn't collide with another profile (dir or label).
  local existing
  existing="$(_profile_dir "$new")"
  if [ "$existing" != "${PROFILE_PREFIX}${new}" ] && [ "$existing" != "$old_dir" ]; then
    _die "profile already exists: $new"
  fi
  if [ -e "${PROFILE_PREFIX}${new}" ] && [ "${PROFILE_PREFIX}${new}" != "$old_dir" ]; then
    _die "profile already exists: $new"
  fi

  if [ "$old_dir" = "$CLAUDE_HOME" ]; then
    # Renaming main: write a label (dir stays at ~/.claude/).
    printf '%s\n' "$new" > "$CLAUDE_HOME/$LABEL_FILE_NAME"
    chmod 600 "$CLAUDE_HOME/$LABEL_FILE_NAME" 2>/dev/null || true
    printf 'Renamed main → %s%s%s\n' "$ORANGE" "$new" "$RESET"
    printf '  %s(label only — %s%s%s stays at %s)%s\n' \
      "$DIM" "$RESET" "$DIM" "$CLAUDE_HOME" "$CLAUDE_HOME" "$RESET"
  else
    # Physical rename for non-main profiles.
    local new_dir="${PROFILE_PREFIX}${new}"
    mv "$old_dir" "$new_dir"
    # Drop any stale label inside the renamed dir — the new dir name is canonical.
    rm -f "$new_dir/$LABEL_FILE_NAME"
    printf 'Renamed %s → %s\n' "$old" "$new"
    printf '  %s%s%s -> %s%s%s\n' "$DIM" "$old_dir" "$RESET" "$ORANGE" "$new_dir" "$RESET"
    # Warn if the renamed profile is active in the caller's shell.
    if [ "${CLAUDE_CONFIG_DIR:-}" = "$old_dir" ]; then
      printf '\n%s⚠%s  Your current shell has CLAUDE_CONFIG_DIR pointing at the old path.\n' "$YELLOW" "$RESET"
      printf '   Run %scca switch %s%s to update this shell.\n' "$BOLD" "$new" "$RESET"
    fi
  fi
}

cmd_rm() {
  local name="${1:-}"
  [ -n "$name" ] || _die "usage: cca rm <name>"
  local dir
  dir="$(_profile_dir "$name")"
  [ -d "$dir" ] || _die "no such profile: $name"
  [ "$dir" != "$CLAUDE_HOME" ] || _die "cannot remove the main profile (it lives at $CLAUDE_HOME)"
  printf 'About to delete profile dir: %s\n' "$dir"
  printf 'This removes the stored token and per-profile state.\n'
  printf 'Shared items are symlinks; originals in ~/.claude/ are untouched.\n'
  printf 'Type the profile name to confirm: '
  local reply
  read -r reply
  [ "$reply" = "$name" ] || _die "aborted (got: $reply)"
  rm -rf "$dir"
  printf 'Removed %s\n' "$dir"
}

cmd_login() {
  local name="${1:-}"
  [ -n "$name" ] || _die "usage: cca login <name>"
  local dir
  dir="$(_profile_dir "$name")"
  [ -d "$dir" ] || _die "no such profile: $name (run: cca add $name)"
  [ "$dir" != "$CLAUDE_HOME" ] || _die "the main profile uses Keychain — run 'claude /login' directly"

  _info ""
  _info "About to run 'claude setup-token' to generate a long-lived OAuth token for"
  _info "profile '$name'. This will open your browser. Log in with the account you"
  _info "want to associate with this profile, then return here."
  _info ""
  _info "Press Enter to continue (or Ctrl+C to cancel)..."
  read -r _

  _info ""
  _info "─── claude setup-token ───"
  claude setup-token
  _info "───────────────────────────"
  _info ""
  _info "Copy the OAuth token printed above. (Input is hidden as you paste.)"
  printf 'Paste token for %s: ' "$name" >&2
  local token
  read -r -s token
  echo >&2

  [ -n "$token" ] || _die "no token provided"

  # Basic sanity check: tokens look like long opaque strings
  if [ "${#token}" -lt 20 ]; then
    _die "that doesn't look like a token (got ${#token} chars)"
  fi

  # Save with restrictive permissions
  local token_file="$dir/$TOKEN_FILE_NAME"
  umask 077
  printf '%s' "$token" > "$token_file"
  chmod 600 "$token_file"

  _info "Saved token for '$name' to $token_file (mode 0600)"
  _info ""
  if [ "${CCA_WRAPPED:-}" = "1" ]; then
    _info "Next: cca switch $name"
  else
    _info "Next: eval \"\$(cca switch $name)\""
    _info "      (or run 'cca init' first to skip the eval dance)"
  fi
}

cmd_switch() {
  local name="${1:-}"
  [ -n "$name" ] || _die "usage: cca switch <name>"

  # If stdout is a TTY, the user almost certainly ran `cca switch X` directly
  # without `eval "$(...)"`. The export lines we print won't affect their
  # shell. Warn loudly and tell them how to fix it.
  _maybe_warn_not_eval() {
    if [ -t 1 ]; then
      cat >&2 <<EOF

⚠  Heads up — these export lines won't change your shell unless you eval them.
   Run instead:
       eval "\$(cca switch $name)"
   Or install the wrapper function once with:
       eval "\$(cca init zsh)"            # try this in your shell
       cca init zsh >> ~/.zshrc           # persist for new shells
   After that, plain \`cca switch $name\` works.

EOF
    fi
  }

  local dir token
  dir="$(_profile_dir "$name")"

  if [ "$dir" = "$CLAUDE_HOME" ]; then
    # Switching to the main profile (regardless of label): unset both vars
    # so Keychain creds resume.
    _maybe_warn_not_eval
    printf 'unset CLAUDE_CONFIG_DIR CLAUDE_CODE_OAUTH_TOKEN\n'
    _info "cca: switched to $name (Keychain auth)."
    return
  fi

  [ -d "$dir" ] || _die "no such profile: $name (run: cca add $name)"
  token="$(_read_token "$dir")"
  [ -n "$token" ] || _die "no token saved for $name (run: cca login $name)"

  _maybe_warn_not_eval
  printf 'export CLAUDE_CONFIG_DIR=%q\n' "$dir"
  printf 'export CLAUDE_CODE_OAUTH_TOKEN=%q\n' "$token"
  _info "cca: switched to $name."
}

# Detect the user's shell from $SHELL (basename), with fallback to zsh.
_detect_shell() {
  local s="${SHELL:-}"
  case "${s##*/}" in
    zsh)  printf 'zsh'  ;;
    bash) printf 'bash' ;;
    *)    printf '%s' "${s##*/}" ;;
  esac
}

# Resolve the rc file we'd append the wrapper to, given a shell name.
_rc_file_for() {
  case "$1" in
    zsh)
      printf '%s/.zshrc' "$HOME"
      ;;
    bash)
      # macOS: ~/.bash_profile is what login shells read. Prefer it if it
      # exists, otherwise ~/.bashrc.
      if [ -f "$HOME/.bash_profile" ]; then
        printf '%s/.bash_profile' "$HOME"
      else
        printf '%s/.bashrc' "$HOME"
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

# Short, friendly prompt header — used by default.
_show_init_short() {
  local rc="$1"
  {
    printf '\n'
    printf 'cca needs a small wrapper in %s%s%s so %scca switch X%s works in your current shell.\n' \
      "$ORANGE" "$rc" "$RESET" "$BOLD" "$RESET"
    printf '\n'
  } >&2
}

# Detailed view — shown when user picks `?` or passes --verbose.
_show_init_details() {
  local rc="$1"
  {
    printf '\n'
    printf '%sWhy:%s a child process can'\''t change its parent shell'\''s env vars.\n' "$BOLD" "$RESET"
    printf '%s     %scca switch X%s only %sprints%s export lines; the wrapper intercepts and\n' \
      "$DIM" "$ORANGE" "$DIM" "$BOLD" "$DIM"
    printf '%s     auto-evals them, so env changes stick. Other subcommands pass through.%s\n' "$DIM" "$RESET"
    printf '\n'
    printf '%sWill append to %s%s%s:\n' "$BOLD" "$ORANGE" "$rc" "$RESET"
    _emit_wrapper | sed "s/^/${DIM}  │  ${RESET}/"
    printf '\n'
  } >&2
}

# Y/n prompt. Returns 0 on yes, 1 on no.
_prompt_yn_init() {
  local reply
  printf '%sInstall?%s [Y]es  [n]o ' "$BOLD" "$RESET" >&2
  read -r reply
  case "$reply" in
    ''|y|Y|yes|YES) return 0 ;;
    *)              return 1 ;;
  esac
}

# Y/n/? prompt. On ? shows details once, then falls through to Y/n.
# Returns 0 on yes, 1 on no.
_prompt_yn_init_with_details() {
  local rc="$1" reply
  printf '%sInstall?%s [Y]es  [n]o  [?] show details ' "$BOLD" "$RESET" >&2
  read -r reply
  case "$reply" in
    \?)
      _show_init_details "$rc"
      _prompt_yn_init
      ;;
    ''|y|Y|yes|YES) return 0 ;;
    *)              return 1 ;;
  esac
}

# Emit the wrapper function for a shell (zsh or bash; same syntax).
# Exports CCA_WRAPPED=1 so subprocess `cca` calls can detect when they're
# running under a wrapped shell (and skip the "reload your shell" nag).
_emit_wrapper() {
  cat <<'SHELL'
# cca shell wrapper — makes `cca switch X` and bare `cca` (picker) modify
# the current shell directly. Installed by `cca init`.
export CCA_WRAPPED=1
cca() {
  case "${1:-}" in
    switch|sw|'')
      local _out
      _out="$(command cca "$@")" || return $?
      [ -n "$_out" ] && eval "$_out"
      ;;
    *)
      command cca "$@"
      ;;
  esac
}
SHELL
}

cmd_init() {
  local yes=0
  local print_only=0
  local verbose=0
  local shell=""

  # Args (order-independent):
  #   --yes / -y     skip the interactive confirmation
  #   --print        print the wrapper to stdout instead of installing
  #   --verbose      show the detailed "why" + full code block by default
  #   zsh | bash     force a shell (overrides $SHELL detection)
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes|-y)      yes=1 ;;
      --print)       print_only=1 ;;
      --verbose)     verbose=1 ;;
      zsh|bash)      shell="$1" ;;
      '')            ;;
      *)             _die "unknown arg: $1 (usage: cca init [zsh|bash] [--yes] [--print] [--verbose])" ;;
    esac
    shift
  done

  if [ -z "$shell" ]; then
    shell="$(_detect_shell)"
  fi

  case "$shell" in
    zsh|bash) ;;
    *) _die "unsupported shell: ${shell:-<unknown>} (set \$SHELL to /bin/zsh or /bin/bash, or pass: cca init zsh|bash)" ;;
  esac

  # --print mode: emit wrapper, no side effects.
  if [ "$print_only" -eq 1 ]; then
    _emit_wrapper
    return 0
  fi

  local rc
  rc="$(_rc_file_for "$shell")" || _die "couldn't resolve rc file for $shell"

  # Already installed? Bail out cleanly.
  if [ -f "$rc" ] && grep -q "^# cca shell wrapper" "$rc"; then
    if [ "${CCA_WRAPPED:-}" = "1" ]; then
      printf '%s✓%s cca: wrapper already installed and active in this shell.\n' "$GREEN" "$RESET" >&2
    else
      printf '%s✓%s cca: wrapper already installed in %s%s%s\n' "$GREEN" "$RESET" "$ORANGE" "$rc" "$RESET" >&2
      printf '  To activate it in this shell: %ssource %s%s\n' "$BOLD" "$rc" "$RESET" >&2
    fi
    return 0
  fi

  # Confirm before writing, unless --yes was passed or stdin isn't a TTY
  # (in pipelines / scripts, default to non-interactive install).
  if [ "$yes" -eq 0 ] && [ -t 0 ]; then
    if [ "$verbose" -eq 1 ]; then
      _show_init_details "$rc"
      _prompt_yn_init "$rc" || { _info "cca: aborted, no changes made."; return 1; }
    else
      _show_init_short "$rc"
      _prompt_yn_init_with_details "$rc" || { _info "cca: aborted, no changes made."; return 1; }
    fi
  fi

  {
    printf '\n'
    _emit_wrapper
  } >> "$rc"
  printf '%s✓%s cca: wrapper appended to %s%s%s\n' "$GREEN" "$RESET" "$ORANGE" "$rc" "$RESET" >&2
  printf '\n' >&2
  printf '  To activate in this shell (pick one):\n' >&2
  printf '    %ssource %s%s          %s# gentler — keeps shell state%s\n' "$BOLD" "$rc" "$RESET" "$DIM" "$RESET" >&2
  printf '    %sexec %s%s             %s# nuclear — fresh shell%s\n' "$BOLD" "$shell" "$RESET" "$DIM" "$RESET" >&2
  printf '\n' >&2
  printf '  %sNew terminal windows pick it up automatically.%s\n' "$DIM" "$RESET" >&2
}

cmd_usage() {
  local show_all=0 target=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --all|-a) show_all=1 ;;
      '')       ;;
      *)        target="$1" ;;
    esac
    shift
  done

  if [ "$show_all" -eq 1 ]; then
    local dir name first=1
    while read -r dir; do
      [ -d "$dir" ] || continue
      name="$(_profile_name_of_dir "$dir")"
      [ "$first" -eq 1 ] || printf '\n'
      first=0
      _usage_one "$name"
    done < <(_list_profile_dirs)
    return
  fi

  if [ -z "$target" ]; then
    # Default: usage for the currently-active profile.
    target="$(_profile_name_of_dir "$(_active_dir)")"
  fi
  _usage_one "$target"
}

_usage_one() {
  local name="$1"
  local dir
  dir="$(_profile_dir "$name")"
  if [ ! -d "$dir" ]; then
    _warn "no such profile: $name"; return
  fi

  # Read all JSONL session transcripts in the profile and render a /stats-like
  # heatmap + summary. No external deps — uses the Python that's already on
  # PATH for the rest of cca.
  /usr/bin/env python3 - "$dir" "$name" "${BOLD}" "${DIM}" "${GREEN}" "${ORANGE}" "${RESET}" <<'PY'
import json, os, sys
from collections import defaultdict, Counter
from datetime import datetime, timedelta, date

profile_dir = sys.argv[1]
display     = sys.argv[2]
BOLD, DIM, GREEN, ORANGE, RESET = sys.argv[3:8]

projects = os.path.join(profile_dir, "projects")
if not os.path.isdir(projects):
    print(f"  {BOLD}{ORANGE}{display}{RESET}: no usage yet (no projects/ directory)")
    sys.exit(0)

day_tokens     = defaultdict(int)     # date -> total tokens
day_sessions   = defaultdict(set)     # date -> set(session_id)
model_tokens   = Counter()            # model -> tokens
sessions       = {}                   # session_id -> (first_ts, last_ts, tokens)

def ts(obj):
    t = obj.get("timestamp")
    if not t: return None
    try: return datetime.fromisoformat(t.replace("Z", "+00:00"))
    except Exception: return None

for root, _, files in os.walk(projects):
    for fname in files:
        if not fname.endswith(".jsonl"): continue
        sid = fname[:-6]
        path = os.path.join(root, fname)
        first = last = None
        stoks = 0
        try:
            with open(path, errors="ignore") as fh:
                for line in fh:
                    try: obj = json.loads(line)
                    except Exception: continue
                    dt = ts(obj)
                    if dt and (first is None or dt < first): first = dt
                    if dt and (last  is None or dt > last):  last  = dt
                    msg = obj.get("message") or {}
                    if msg.get("role") != "assistant": continue
                    usage = msg.get("usage") or {}
                    n = (usage.get("input_tokens", 0) or 0) + \
                        (usage.get("output_tokens", 0) or 0) + \
                        (usage.get("cache_creation_input_tokens", 0) or 0) + \
                        (usage.get("cache_read_input_tokens", 0) or 0)
                    if n and dt:
                        d = dt.date()
                        day_tokens[d]   += n
                        day_sessions[d].add(sid)
                        stoks           += n
                    model = msg.get("model")
                    if model and n:
                        model_tokens[model] += n
        except Exception:
            continue
        if first and last:
            sessions[sid] = (first, last, stoks)

# ── heatmap ──
today = date.today()
start = today - timedelta(days=365)
start = start - timedelta(days=(start.weekday() + 1) % 7)  # align to Sunday

cols = []
d = start
while d <= today:
    week = [day_tokens.get(d + timedelta(days=i), 0) for i in range(7)]
    cols.append((d, week))
    d += timedelta(days=7)

nonzero = [v for v in day_tokens.values() if v > 0]
peak = max(nonzero) if nonzero else 1
def density(v):
    if v == 0:
        return f"{DIM}·{RESET}"
    r = v / peak
    if r < 0.2: ch = "░"
    elif r < 0.4: ch = "▒"
    elif r < 0.7: ch = "▓"
    else: ch = "█"
    return f"{ORANGE}{ch}{RESET}"

# Month labels: 3-letter abbrev at the first col of each month, truncated
# to fit if the month has fewer than 3 visible weeks (at heatmap edges).
month_line = " " * 6
i = 0
while i < len(cols):
    d_, _ = cols[i]
    # Find where this month ends.
    end = i
    while end < len(cols) and cols[end][0].month == d_.month:
        end += 1
    weeks_in_month = end - i
    label = d_.strftime("%b")[:weeks_in_month]
    month_line += label + " " * (weeks_in_month - len(label))
    i = end

print()
print(f"  {BOLD}{ORANGE}{display}{RESET}")
print()
print(f"  {DIM}{month_line.rstrip()}{RESET}")

day_names = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"]
for i in range(7):
    label = day_names[i] if i in (1, 3, 5) else "   "
    row = f"  {DIM}{label:<4}{RESET}"
    for _, week in cols:
        row += density(week[i])
    print(row)

print()
print(f"  {DIM}Less{RESET} {ORANGE}░ ▒ ▓ █{RESET} {DIM}More{RESET}")
print()

# ── summary ──
def fmt(n):
    if n >= 1_000_000_000: return f"{n/1_000_000_000:.1f}b"
    if n >= 1_000_000:     return f"{n/1_000_000:.1f}m"
    if n >= 1_000:         return f"{n/1_000:.1f}k"
    return str(n)

def dur(td):
    d = td.days
    h = td.seconds // 3600
    m = (td.seconds % 3600) // 60
    if d: return f"{d}d {h}h {m}m"
    if h: return f"{h}h {m}m"
    return f"{m}m"

total = sum(day_tokens.values())
unique_sessions = len({s for ss in day_sessions.values() for s in ss})
active_days = sum(1 for v in day_tokens.values() if v > 0)
window_days = (today - start).days + 1

def pretty_model(name):
    # "claude-opus-4-7"   → "Opus 4.7"
    # "claude-sonnet-4-6" → "Sonnet 4.6"
    # "claude-haiku-4-5"  → "Haiku 4.5"
    import re
    m = re.match(r"^claude-(opus|sonnet|haiku)-(\d+)-(\d+)", name)
    if m:
        return f"{m.group(1).capitalize()} {m.group(2)}.{m.group(3)}"
    return name

fav = pretty_model(model_tokens.most_common(1)[0][0]) if model_tokens else "—"
longest = "—"
# Only count sessions that actually produced tokens — bare-init files don't count.
real_sessions = {sid: v for sid, v in sessions.items() if v[2] > 0}
if real_sessions:
    longest_td = max(e - s for s, e, _ in real_sessions.values())
    longest = dur(longest_td) if longest_td.total_seconds() else "—"

most_active = "—"
if day_tokens:
    md = max(day_tokens.items(), key=lambda x: x[1])[0]
    most_active = md.strftime("%b %d")

active_set = sorted(d for d, v in day_tokens.items() if v > 0)
longest_streak = current_streak = 0
if active_set:
    run = 1
    for i in range(1, len(active_set)):
        if (active_set[i] - active_set[i-1]).days == 1: run += 1
        else: longest_streak = max(longest_streak, run); run = 1
    longest_streak = max(longest_streak, run)
    check = today
    while day_tokens.get(check, 0) > 0:
        current_streak += 1
        check -= timedelta(days=1)

L = 38  # left column width
def row(left_lbl, left_val, right_lbl, right_val):
    left = f"  {DIM}{left_lbl}{RESET} {ORANGE}{left_val}{RESET}"
    # account for ANSI codes when padding
    pad = L - len(f"  {left_lbl} {left_val}")
    if pad < 2: pad = 2
    print(left + " " * pad + f"{DIM}{right_lbl}{RESET} {ORANGE}{right_val}{RESET}")

row("Favorite model:", fav,                  "Total tokens:",    fmt(total))
row("Sessions:",       str(unique_sessions), "Longest session:", longest)
row("Active days:",    f"{active_days}/{window_days}", "Longest streak:", f"{longest_streak} days")
row("Most active day:", most_active,         "Current streak:",  f"{current_streak} days")
PY
}

# ─────────────────────────────────────────────────────────────────────────────
# main
# ─────────────────────────────────────────────────────────────────────────────

main() {
  # No args: interactive profile picker if we're on a TTY, otherwise help.
  if [ $# -eq 0 ]; then
    if [ -t 0 ] && [ -t 2 ]; then
      local picked
      picked="$(_picker)" || return 1
      [ -n "$picked" ] || return 1
      cmd_switch "$picked"
      return $?
    else
      cmd_help
      return
    fi
  fi

  local cmd="$1"
  shift
  case "$cmd" in
    help|-h|--help)        cmd_help "$@" ;;
    version|-v|--version)  cmd_version ;;
    ls|list)               cmd_ls "$@" ;;
    active|current)        cmd_active "$@" ;;
    add|new)               cmd_add "$@" ;;
    sync)                  cmd_sync "$@" ;;
    refresh)               cmd_refresh "$@" ;;
    rm|remove|delete)      cmd_rm "$@" ;;
    rename|mv)             cmd_rename "$@" ;;
    login)                 cmd_login "$@" ;;
    switch|sw)             cmd_switch "$@" ;;
    usage)                 cmd_usage "$@" ;;
    init)                  cmd_init "$@" ;;
    *) _die "unknown command: $cmd (try 'cca help')" ;;
  esac
}

main "$@"
